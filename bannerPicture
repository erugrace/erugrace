<svg width="100%" height="190" viewBox="0 0 900 190" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <!-- Background gradient -->
    <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0B0F19;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#0D1526;stop-opacity:1" />
    </linearGradient>

    <!-- Name title gradient -->
    <linearGradient id="titleGrad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#FFFFFF;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#A5B4FC;stop-opacity:1" />
    </linearGradient>

    <!-- Cyan glow left -->
    <radialGradient id="glowLeft" cx="0%" cy="0%" r="60%">
      <stop offset="0%" style="stop-color:#00F2FE;stop-opacity:0.12" />
      <stop offset="100%" style="stop-color:#00F2FE;stop-opacity:0" />
    </radialGradient>

    <!-- Purple glow right -->
    <radialGradient id="glowRight" cx="100%" cy="100%" r="60%">
      <stop offset="0%" style="stop-color:#4FACFE;stop-opacity:0.10" />
      <stop offset="100%" style="stop-color:#4FACFE;stop-opacity:0" />
    </radialGradient>

    <!-- Subtle border gradient -->
    <linearGradient id="borderGrad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#00F2FE;stop-opacity:0.3" />
      <stop offset="50%" style="stop-color:#4FACFE;stop-opacity:0.15" />
      <stop offset="100%" style="stop-color:#00F2FE;stop-opacity:0.3" />
    </linearGradient>

    <clipPath id="roundedClip">
      <rect width="900" height="190" rx="14" ry="14"/>
    </clipPath>
  </defs>

  <!-- Rounded background card -->
  <rect width="900" height="190" rx="14" ry="14" fill="url(#bgGrad)" />

  <!-- Glow orbs -->
  <rect width="900" height="190" rx="14" ry="14" fill="url(#glowLeft)" clip-path="url(#roundedClip)" />
  <rect width="900" height="190" rx="14" ry="14" fill="url(#glowRight)" clip-path="url(#roundedClip)" />

  <!-- Grid lines horizontal -->
  <g clip-path="url(#roundedClip)" opacity="0.04" stroke="#FFFFFF" stroke-width="0.5">
    <line x1="0" y1="30" x2="900" y2="30"/>
    <line x1="0" y1="60" x2="900" y2="60"/>
    <line x1="0" y1="90" x2="900" y2="90"/>
    <line x1="0" y1="120" x2="900" y2="120"/>
    <line x1="0" y1="150" x2="900" y2="150"/>
    <line x1="0" y1="180" x2="900" y2="180"/>
    <!-- Grid lines vertical -->
    <line x1="90" y1="0" x2="90" y2="190"/>
    <line x1="180" y1="0" x2="180" y2="190"/>
    <line x1="270" y1="0" x2="270" y2="190"/>
    <line x1="360" y1="0" x2="360" y2="190"/>
    <line x1="450" y1="0" x2="450" y2="190"/>
    <line x1="540" y1="0" x2="540" y2="190"/>
    <line x1="630" y1="0" x2="630" y2="190"/>
    <line x1="720" y1="0" x2="720" y2="190"/>
    <line x1="810" y1="0" x2="810" y2="190"/>
  </g>

  <!-- Rounded border glow -->
  <rect width="898" height="188" x="1" y="1" rx="13" ry="13" fill="none" stroke="url(#borderGrad)" stroke-width="1"/>

  <!-- "System Online" tag background -->
  <rect x="355" y="22" width="190" height="22" rx="11" ry="11" fill="#00F2FE" fill-opacity="0.07" stroke="#00F2FE" stroke-opacity="0.25" stroke-width="1"/>

  <!-- "System Online" tag text -->
  <text x="450" y="37.5" text-anchor="middle" font-family="'Segoe UI', Arial, sans-serif" font-size="9" font-weight="700" letter-spacing="3" fill="#00F2FE" opacity="0.9">SYSTEM ONLINE</text>

  <!-- Main name -->
  <text x="450" y="96" text-anchor="middle" font-family="'Segoe UI', Arial, sans-serif" font-size="40" font-weight="800" letter-spacing="-0.5" fill="url(#titleGrad)">Grace Sodipo</text>

  <!-- Subtitle left line -->
  <line x1="260" y1="114" x2="300" y2="114" stroke="#4FACFE" stroke-width="1" opacity="0.5"/>
  <!-- Subtitle text -->
  <text x="450" y="118" text-anchor="middle" font-family="'Segoe UI', Arial, sans-serif" font-size="13" font-weight="400" letter-spacing="0.5" fill="#94A3B8">Software Engineer &amp; Health Tech Enthusiast</text>
  <!-- Subtitle right line -->
  <line x1="600" y1="114" x2="640" y2="114" stroke="#4FACFE" stroke-width="1" opacity="0.5"/>

  <!-- Left status pill background -->
  <rect x="244" y="134" width="188" height="24" rx="6" ry="6" fill="#FFFFFF" fill-opacity="0.02" stroke="#FFFFFF" stroke-opacity="0.06" stroke-width="1"/>
  <!-- Left dot -->
  <circle cx="260" cy="146" r="3.5" fill="#00F2FE" opacity="0.9"/>
  <!-- Left pill text -->
  <text x="270" y="150.5" font-family="'Segoe UI', Arial, sans-serif" font-size="10.5" fill="#E2E8F0" opacity="0.85">Building solutions</text>

  <!-- Right status pill background -->
  <rect x="462" y="134" width="188" height="24" rx="6" ry="6" fill="#FFFFFF" fill-opacity="0.02" stroke="#4FACFE" stroke-opacity="0.12" stroke-width="1"/>
  <!-- Right dot -->
  <circle cx="478" cy="146" r="3.5" fill="#4FACFE" opacity="0.9"/>
  <!-- Right pill text -->
  <text x="488" y="150.5" font-family="'Segoe UI', Arial, sans-serif" font-size="10.5" fill="#E2E8F0" opacity="0.85">Always learning</text>
</svg>
